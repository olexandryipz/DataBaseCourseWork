@model PerfumeStore.Models.Perfume

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    @* Блок для показу повідомлення про успішну покупку *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" style="border-left: 5px solid #D4AF37;">
            <strong>Успіх!</strong> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0" style="border-radius: 15px; overflow: hidden;">
        <div class="row g-0">
            <div class="col-md-5">
                <img src="/images/@(Model.Name.ToLower().Replace(" ", "")).jpg"
                     onerror="this.src='https://images.unsplash.com/photo-1541643600914-78b084683601?q=80&w=500'"
                     class="img-fluid h-100 w-100" style="object-fit: cover; min-height: 400px;" alt="@Model.Name">
            </div>
            <div class="col-md-7">
                <div class="card-body p-5">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="text-uppercase mb-0" style="color: #D4AF37; letter-spacing: 2px;">@Model.Brand.Name</h6>
                        <span class="badge bg-dark">@Model.Category.Name</span>
                    </div>
                    <h1 class="display-5 fw-bold mb-4" style="font-family: 'Playfair Display', serif;">@Model.Name</h1>

                    <h2 class="text-primary mb-4">@Model.Price.ToString("N2") ₴</h2>

                    <div class="mb-4">
                        <p class="text-muted"><i class="bi bi-droplet-fill" style="color: #D4AF37;"></i> Об'єм: <strong>@Model.Volume мл</strong></p>
                        @* ОСЬ ТУТ МИ ВИВОДИМО ЗАЛИШОК НА СКЛАДІ *@
                        <p class="text-muted"><i class="bi bi-box-seam-fill" style="color: #D4AF37;"></i> Залишок на складі: <strong>@(Model.StockQuantity) шт.</strong></p>
                    </div>

                    <hr class="mb-4">

                    @* ФОРМА ПОКУПКИ (Доступна тільки для тих, хто увійшов) *@
                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-action="Buy" asp-controller="Perfumes" method="post" class="row g-3 align-items-center">
                            <input type="hidden" name="perfumeId" value="@Model.PerfumeId" />
                            <div class="col-auto">
                                <label for="quantity" class="col-form-label fw-bold">Кількість:</label>
                            </div>
                            <div class="col-auto">
                                <input type="number" id="quantity" name="quantity" class="form-control" value="1" min="1" max="100" style="width: 80px;">
                            </div>
                            <div class="col-auto">
                                <button type="submit" class="btn btn-lg text-dark fw-bold px-5" style="background-color: #D4AF37;">Купити зараз</button>
                            </div>
                        </form>
                    }
                    else
                    {
                        <div class="alert alert-secondary border-0 border-start border-4 border-warning">
                            Щоб зробити замовлення, будь ласка, <a asp-area="Identity" asp-page="/Account/Login" class="alert-link text-decoration-none">увійдіть в акаунт</a> або <a asp-area="Identity" asp-page="/Account/Register" class="alert-link text-decoration-none">зареєструйтеся</a>.
                        </div>
                    }

                    <div class="mt-4 pt-3">
                        <a asp-action="Index" class="text-decoration-none text-secondary"><i class="bi bi-arrow-left"></i> Повернутися до колекції</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>