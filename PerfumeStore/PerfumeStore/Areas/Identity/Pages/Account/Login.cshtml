@page
@model LoginModel

@{
    ViewData["Title"] = "Увійти";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow-sm" style="border-top: 3px solid #D4AF37;">
            <div class="card-body p-4">
                <h2 class="text-center mb-4" style="font-family: 'Playfair Display', serif;">Увійти до акаунту</h2>
                <hr />
                <form id="account" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                        <label asp-for="Input.Email">Електронна пошта</label>
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                        <label asp-for="Input.Password">Пароль</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <div class="checkbox mb-4">
                        <label asp-for="Input.RememberMe" class="form-label">
                            <input class="form-check-input" asp-for="Input.RememberMe" />
                            Запам'ятати мене
                        </label>
                    </div>

                    <button id="login-submit" type="submit" class="w-100 btn btn-lg text-dark fw-bold mb-3" style="background-color: #D4AF37;">Увійти</button>

                    <div class="text-center">
                        <p class="mb-0">
                            <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="text-decoration-none" style="color: #b5952f; font-weight: 600;">Немає акаунту? Зареєструватися</a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* Цей блок скриптів повернуто завдяки твоїй уважності! *@
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}